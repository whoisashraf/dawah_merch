<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Production Summary</h1>
  <p class="text-gray-500 text-sm mt-1">Size breakdown for paid orders</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <% @summary.each do |product, sizes| %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-gray-900 text-lg mb-4"><%= product.name %></h2>
      <% if sizes.any? %>
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left py-2 px-3 text-gray-600 font-semibold">Size</th>
              <th class="text-right py-2 px-3 text-gray-600 font-semibold">Count</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% sizes.each do |size, count| %>
              <tr>
                <td class="py-2 px-3 text-gray-900 font-medium"><%= size %></td>
                <td class="py-2 px-3 text-right text-gray-900 font-bold text-lg"><%= count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-gray-400 text-sm">No paid orders with sizes yet</p>
      <% end %>
    </div>
  <% end %>

  <% if @summary.empty? %>
    <div class="md:col-span-2 bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <p class="text-gray-400 text-center">No products with sizes configured</p>
    </div>
  <% end %>
</div>
