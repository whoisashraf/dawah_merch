<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
  <div>
    <span class="sticker-badge sticker-badge-yellow mb-2">DATABASE VIEWS</span>
    <div class="flex items-center gap-4 flex-wrap">
      <h1 class="font-display font-black text-3xl md:text-5xl mt-2 text-black">Orders</h1>
      <%= link_to "+ Offline Order", new_admin_order_path, class: "neo-btn-yellow py-1.5 px-3.5 text-xs shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-y-0.5 active:translate-y-1 transition-all rounded-pill font-black text-black border-2 border-black bg-accent-1" %>
    </div>
    <p class="text-xs font-bold text-gray-500 mt-1.5"><%= @orders.count %> total orders listed</p>
  </div>
  
  <!-- Tactile Tabs -->
  <div class="flex flex-wrap gap-2 text-xs font-black uppercase tracking-wider">
    <%= link_to "Paid", admin_orders_path, class: "border-2 border-black px-3.5 py-2 rounded-lg transition-all shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5 #{params[:payment_status].nil? && params[:status].nil? && params[:pending_proofread].nil? ? 'bg-black text-white shadow-none translate-y-0.5' : 'bg-white text-black'}" %>
    <%= link_to "All", admin_orders_path(payment_status: "all"), class: "border-2 border-black px-3.5 py-2 rounded-lg transition-all shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5 #{params[:payment_status] == 'all' ? 'bg-black text-white shadow-none translate-y-0.5' : 'bg-white text-black'}" %>
    <%= link_to "Unpaid", admin_orders_path(payment_status: "unpaid"), class: "border-2 border-black px-3.5 py-2 rounded-lg transition-all shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5 #{params[:payment_status] == 'unpaid' ? 'bg-black text-white shadow-none translate-y-0.5' : 'bg-white text-black'}" %>
    <%= link_to "Processing", admin_orders_path(status: "processing"), class: "border-2 border-black px-3.5 py-2 rounded-lg transition-all shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5 #{params[:status] == 'processing' ? 'bg-black text-white shadow-none translate-y-0.5' : 'bg-white text-black'}" %>
    <%= link_to "Collected", admin_orders_path(status: "collected"), class: "border-2 border-black px-3.5 py-2 rounded-lg transition-all shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5 #{params[:status] == 'collected' ? 'bg-black text-white shadow-none translate-y-0.5' : 'bg-white text-black'}" %>
  </div>
</div>

<!-- Proofreading alerts -->
<% if params[:pending_proofread] && @pending_proofread_items.any? %>
  <div class="neo-card bg-primary-bg overflow-hidden border-accent-2 mb-8 grain-bg">
    <div class="px-6 py-4 border-b-3 border-black bg-accent-1/20 flex items-center justify-between">
      <h2 class="font-display font-black text-lg text-black flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-accent-2 animate-pulse"></span>
        Proofread: <%= @pending_proofread_items.count %> Custom Name<%= "s" if @pending_proofread_items.count != 1 %> Pending Review
      </h2>
      <a href="<%= admin_orders_path %>" class="text-xs font-black uppercase tracking-wider text-gray-500 hover:text-black">Dismiss</a>
    </div>
    <div class="divide-y-2 divide-black/10">
      <% @pending_proofread_items.each do |item| %>
        <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-black text-black"><%= item.order.student_name %></p>
            <p class="text-xs text-gray-600 mt-1 font-semibold">
              Product: <span class="text-black font-extrabold"><%= item.product.name %></span>
              Proposed Print: <span class="bg-accent-1 px-1.5 py-0.5 rounded border border-black font-mono text-black font-black">"<%= item.custom_name %>"</span>
              <span class="text-gray-400 font-normal">· Ref: <%= item.order.reference %></span>
            </p>
          </div>
          <div class="flex gap-2 shrink-0">
            <%= button_to "Approve", approve_admin_proofread_path(item), method: :patch, class: "border-2 border-black bg-white text-black hover:bg-accent-3 hover:text-white px-3.5 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-all cursor-pointer shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5" %>
            <%= button_to "Reject", reject_admin_proofread_path(item), method: :patch, class: "border-2 border-black bg-white text-black hover:bg-accent-2 hover:text-white px-3.5 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-all cursor-pointer shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Orders Table -->
<div class="neo-card bg-white overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm border-collapse text-left">
      <thead class="bg-white border-b-3 border-black font-black uppercase tracking-wider text-xs">
        <tr>
          <th class="py-4 px-6 border-r-2 border-black/10">Reference</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Student</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Phone</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Delivery</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-right">Amount</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Payment</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Status</th>
          <th class="py-4 px-6"></th>
        </tr>
      </thead>
      <tbody class="divide-y-2 divide-black/10 font-semibold">
        <% @orders.each do |order| %>
          <tr class="hover:bg-primary-bg/10 transition-colors">
            <td class="py-3.5 px-6 font-mono text-xs text-accent-3 font-bold border-r-2 border-black/10"><%= order.reference %></td>
            <td class="py-3.5 px-6 text-black font-bold border-r-2 border-black/10"><%= order.student_name %></td>
            <td class="py-3.5 px-6 text-gray-600 border-r-2 border-black/10"><%= order.phone %></td>
            <td class="py-3.5 px-6 text-gray-500 text-xs border-r-2 border-black/10"><%= order.delivery_label %></td>
            <td class="py-3.5 px-6 text-right text-black font-black border-r-2 border-black/10"><%= naira(order.total_amount) %></td>
            <td class="py-3.5 px-6 text-center border-r-2 border-black/10">
              <% if order.paid? %>
                <span class="border-2 border-black bg-accent-1 text-black text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]">Paid</span>
              <% else %>
                <span class="border-2 border-black bg-white text-gray-400 text-[10px] font-black uppercase px-2 py-0.5 rounded">Unpaid</span>
              <% end %>
            </td>
            <td class="py-3.5 px-6 text-center border-r-2 border-black/10">
              <span class="text-xs uppercase font-extrabold text-black"><%= order.status.humanize %></span>
            </td>
            <td class="py-3.5 px-6 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "View", admin_order_path(order), class: "text-accent-3 hover:text-black font-bold transition-colors text-xs uppercase tracking-wider" %>
                <span class="text-gray-300 font-normal">|</span>
                <%= button_to "Delete", admin_order_path(order), method: :delete,
                  form: { data: { turbo_confirm: "Are you sure you want to permanently delete order ##{order.reference}?" } },
                  class: "text-accent-2 hover:text-red-700 font-bold transition-colors border-none bg-transparent cursor-pointer text-xs uppercase tracking-wider" %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @orders.empty? %>
          <tr>
            <td colspan="8" class="py-16 text-center text-gray-500 font-bold">No orders matched the current filter.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
