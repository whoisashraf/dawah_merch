<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
    <p class="text-gray-500 text-sm mt-1"><%= @orders.count %> total</p>
  </div>
  <div class="flex gap-2 text-sm">
    <%= link_to "Paid", admin_orders_path, class: "px-3 py-1.5 rounded-lg #{params[:payment_status].nil? && params[:status].nil? && params[:pending_proofread].nil? ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} transition-colors" %>
    <%= link_to "All", admin_orders_path(payment_status: "all"), class: "px-3 py-1.5 rounded-lg #{params[:payment_status] == 'all' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} transition-colors" %>
    <%= link_to "Unpaid", admin_orders_path(payment_status: "unpaid"), class: "px-3 py-1.5 rounded-lg #{params[:payment_status] == 'unpaid' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} transition-colors" %>
    <%= link_to "Processing", admin_orders_path(status: "processing"), class: "px-3 py-1.5 rounded-lg #{params[:status] == 'processing' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} transition-colors" %>
    <%= link_to "Collected", admin_orders_path(status: "collected"), class: "px-3 py-1.5 rounded-lg #{params[:status] == 'collected' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} transition-colors" %>
  </div>
</div>

<% if params[:pending_proofread] && @pending_proofread_items.any? %>
  <div class="bg-amber-50 border border-amber-200 rounded-xl overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-amber-200 flex items-center justify-between">
      <h2 class="font-bold text-amber-800 text-sm flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-amber-500"></span>
        Proofread — <%= @pending_proofread_items.count %> custom name<%= "s" if @pending_proofread_items.count != 1 %> to review
      </h2>
      <a href="<%= admin_orders_path %>" class="text-xs text-amber-600 hover:text-amber-700 font-medium">Close</a>
    </div>
    <div class="divide-y divide-amber-200">
      <% @pending_proofread_items.each do |item| %>
        <div class="px-5 py-3 flex items-center justify-between gap-4">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900"><%= item.order.student_name %></p>
            <p class="text-xs text-gray-500 mt-0.5">
              <%= item.product.name %> — "<%= item.custom_name %>"
              <span class="text-gray-400">· <%= item.order.reference %></span>
            </p>
          </div>
          <div class="flex gap-2 shrink-0">
            <%= button_to "Approve", approve_admin_proofread_path(item), method: :patch, class: "bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-medium py-1.5 px-3 rounded-lg transition-colors cursor-pointer" %>
            <%= button_to "Reject", reject_admin_proofread_path(item), method: :patch, class: "bg-red-500 hover:bg-red-600 text-white text-xs font-medium py-1.5 px-3 rounded-lg transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Reference</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Student</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Phone</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Delivery</th>
        <th class="text-right py-3 px-4 text-gray-600 font-semibold">Amount</th>
        <th class="text-center py-3 px-4 text-gray-600 font-semibold">Payment</th>
        <th class="text-center py-3 px-4 text-gray-600 font-semibold">Status</th>
        <th class="text-right py-3 px-4 text-gray-600 font-semibold"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @orders.each do |order| %>
        <tr class="hover:bg-gray-50">
          <td class="py-3 px-4 font-mono text-xs text-gray-700"><%= order.reference %></td>
          <td class="py-3 px-4 text-gray-900 font-medium"><%= order.student_name %></td>
          <td class="py-3 px-4 text-gray-500"><%= order.phone %></td>
          <td class="py-3 px-4 text-gray-500 text-xs"><%= order.delivery_label %></td>
          <td class="py-3 px-4 text-right text-gray-900 font-medium"><%= naira(order.total_amount) %></td>
          <td class="py-3 px-4 text-center">
            <% if order.paid? %>
              <span class="text-emerald-600 text-xs font-medium bg-emerald-50 px-2.5 py-1 rounded-lg">Paid</span>
            <% else %>
              <span class="text-amber-600 text-xs font-medium bg-amber-50 px-2.5 py-1 rounded-lg">Unpaid</span>
            <% end %>
          </td>
          <td class="py-3 px-4 text-center text-gray-700"><%= order.status.humanize %></td>
          <td class="py-3 px-4 text-right">
            <%= link_to "View", admin_order_path(order), class: "text-emerald-600 hover:text-emerald-700 text-sm font-medium" %>
          </td>
        </tr>
      <% end %>
      <% if @orders.empty? %>
        <tr>
          <td colspan="8" class="py-12 text-center text-gray-400">No orders found</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
