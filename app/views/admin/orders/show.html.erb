<div class="mb-6">
  <%= link_to admin_orders_path, class: "inline-flex items-center gap-2 text-xs font-black uppercase tracking-wider text-gray-500 hover:text-black" do %>
    <span>←</span> Back to Orders
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
  <div class="md:col-span-2 space-y-8">
    <!-- Order Items Card -->
    <div class="neo-card bg-white overflow-hidden">
      <div class="px-6 py-5 border-b-3 border-black bg-primary-bg/20">
        <h2 class="font-display font-black text-xl text-black">Order Items ✦</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse text-left">
          <thead class="bg-white border-b-3 border-black font-black uppercase tracking-wider text-xs">
            <tr>
              <th class="py-3.5 px-6 border-r-2 border-black/10">Product</th>
              <th class="py-3.5 px-6 border-r-2 border-black/10 text-center">Size</th>
              <th class="py-3.5 px-6 border-r-2 border-black/10">Details & Options</th>
              <th class="py-3.5 px-6 border-r-2 border-black/10 text-center">Qty</th>
              <th class="py-3.5 px-6 border-r-2 border-black/10 text-right">Price</th>
              <th class="py-3.5 px-6 text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y-2 divide-black/10 font-semibold">
            <% @order.order_items.each do |item| %>
              <tr class="hover:bg-primary-bg/5 transition-colors">
                <td class="py-3.5 px-6 text-black font-bold border-r-2 border-black/10"><%= item.product.name %></td>
                <td class="py-3.5 px-6 text-center text-gray-600 border-r-2 border-black/10"><%= item.size || "—" %></td>
                <td class="py-3.5 px-6 border-r-2 border-black/10">
                  <% if item.selected_options.present? %>
                    <span class="text-xs text-gray-500 font-bold block"><%= item.selected_options.values.join(", ") %></span>
                  <% end %>
                  <% if item.custom_name.present? %>
                    <div class="mt-1">
                      <span class="bg-accent-1/40 px-1 py-0.5 rounded border border-black/20 font-mono text-xs text-black font-bold">"<%= item.custom_name %>"</span>
                      <span class="text-[10px] uppercase font-black tracking-wider ml-1.5 <%= item.custom_name_approved ? 'text-accent-3' : item.custom_name_approved == false ? 'text-accent-2' : 'text-amber-500' %>">
                        (<%= item.proofread_status %>)
                      </span>
                    </div>
                  <% end %>
                </td>
                <td class="py-3.5 px-6 text-center border-r-2 border-black/10 text-black font-black"><%= item.quantity %></td>
                <td class="py-3.5 px-6 text-right text-gray-600 border-r-2 border-black/10"><%= naira(item.unit_price) %></td>
                <td class="py-3.5 px-6 text-right text-black font-black"><%= naira(item.subtotal) %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-primary-bg/15 border-t-3 border-black font-black uppercase text-xs">
            <tr>
              <td colspan="5" class="py-4 px-6 text-right text-gray-600 border-r-2 border-black/10">Total Amount</td>
              <td class="py-4 px-6 text-right text-base text-black font-black"><%= naira(@order.total_amount) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <div class="space-y-8">
    <!-- Customer Details Card -->
    <div class="neo-card bg-white p-6">
      <h2 class="font-display font-black text-xl text-black mb-4 border-b-2 border-black/10 pb-2">Customer Profile</h2>
      <dl class="space-y-3.5 text-xs md:text-sm font-semibold">
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Name</dt>
          <dd class="text-black font-bold"><%= @order.student_name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Level</dt>
          <dd class="text-black"><%= @order.level %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Department</dt>
          <dd class="text-black"><%= @order.department %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Phone</dt>
          <dd class="text-black font-mono"><%= @order.phone %></dd>
        </div>
        <% if @order.email.present? %>
          <div class="flex justify-between">
            <dt class="text-gray-500 uppercase tracking-wider">Email</dt>
            <dd class="text-black font-mono"><%= @order.email %></dd>
          </div>
        <% end %>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Delivery</dt>
          <dd class="text-black"><%= @order.delivery_label %></dd>
        </div>
      </dl>
    </div>

    <!-- Status Details Card -->
    <div class="neo-card bg-white p-6">
      <h2 class="font-display font-black text-xl text-black mb-4 border-b-2 border-black/10 pb-2">Order Status</h2>
      <dl class="space-y-3.5 text-xs md:text-sm font-semibold mb-6">
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Payment</dt>
          <dd>
            <% if @order.paid? %>
              <span class="border-2 border-black bg-accent-1 text-black font-black uppercase text-[10px] px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_rgba(0,0,0,1)]">Paid</span>
            <% else %>
              <span class="border-2 border-black bg-white text-gray-400 font-black uppercase text-[10px] px-2 py-0.5 rounded">Unpaid</span>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Order Status</dt>
          <dd class="text-black uppercase font-bold"><%= @order.status.humanize %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Reference</dt>
          <dd class="text-black font-mono text-xs"><%= @order.reference %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 uppercase tracking-wider">Order Date</dt>
          <dd class="text-black text-xs"><%= @order.created_at.strftime("%d %b %Y, %I:%M %p") %></dd>
        </div>
      </dl>

      <% if @order.paid? && @order.status != "collected" %>
        <div class="mt-6 border-t-2 border-black/10 pt-4">
          <a href="<%= @order.whatsapp_url %>" target="_blank" rel="noopener" class="neo-btn-yellow w-full text-center py-2.5 text-xs">
            WhatsApp Customer ✦
          </a>
        </div>
      <% end %>

      <!-- Delete Action -->
      <div class="mt-4 border-t-2 border-black/10 pt-4">
        <%= button_to "Delete Order ✦", admin_order_path(@order), method: :delete,
          form: { data: { turbo_confirm: "Are you sure you want to permanently delete this order?" } },
          class: "neo-btn-outline w-full text-center py-2.5 text-xs text-accent-2 border-accent-2 hover:bg-accent-2 hover:text-white transition-all cursor-pointer font-black" %>
      </div>
    </div>
  </div>
</div>
