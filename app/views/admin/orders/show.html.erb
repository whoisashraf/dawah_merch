<div class="mb-6">
  <%= link_to "← Back to Orders", admin_orders_path, class: "text-sm text-gray-400 hover:text-gray-600" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="md:col-span-2 space-y-6">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-gray-900 text-lg mb-4">Order Items</h2>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left py-2 px-3 text-gray-600 font-semibold">Product</th>
            <th class="text-center py-2 px-3 text-gray-600 font-semibold">Size</th>
            <th class="text-left py-2 px-3 text-gray-600 font-semibold">Custom Name</th>
            <th class="text-right py-2 px-3 text-gray-600 font-semibold">Qty</th>
            <th class="text-right py-2 px-3 text-gray-600 font-semibold">Price</th>
            <th class="text-right py-2 px-3 text-gray-600 font-semibold">Subtotal</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @order.order_items.each do |item| %>
            <tr>
              <td class="py-2 px-3 text-gray-900 font-medium"><%= item.product.name %></td>
              <td class="py-2 px-3 text-center text-gray-500"><%= item.size || "—" %></td>
          <td class="py-2 px-3 text-gray-500">
            <% if item.selected_options.present? %>
              <span class="text-xs"><%= item.selected_options.values.join(", ") %></span>
            <% end %>
            <% if item.custom_name.present? %>
              <div>"<%= item.custom_name %>"
                <span class="text-xs ml-1 <%= item.custom_name_approved ? 'text-emerald-600' : item.custom_name_approved == false ? 'text-red-500' : 'text-amber-500' %>">
                  (<%= item.proofread_status %>)
                </span>
              </div>
            <% end %>
          </td>
              <td class="py-2 px-3 text-right text-gray-900"><%= item.quantity %></td>
              <td class="py-2 px-3 text-right text-gray-600"><%= naira(item.unit_price) %></td>
              <td class="py-2 px-3 text-right text-gray-900 font-medium"><%= naira(item.subtotal) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-gray-50 border-t border-gray-200">
          <tr>
            <td colspan="5" class="py-2 px-3 text-right text-gray-600 font-medium">Total</td>
            <td class="py-2 px-3 text-right text-gray-900 font-bold"><%= naira(@order.total_amount) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="space-y-6">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-gray-900 text-lg mb-4">Customer</h2>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Name</dt>
          <dd class="text-gray-900 font-medium"><%= @order.student_name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Level</dt>
          <dd class="text-gray-900"><%= @order.level %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Dept</dt>
          <dd class="text-gray-900"><%= @order.department %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Phone</dt>
          <dd class="text-gray-900"><%= @order.phone %></dd>
        </div>
        <% if @order.email.present? %>
          <div class="flex justify-between">
            <dt class="text-gray-500">Email</dt>
            <dd class="text-gray-900"><%= @order.email %></dd>
          </div>
        <% end %>
        <div class="flex justify-between">
          <dt class="text-gray-500">Delivery</dt>
          <dd class="text-gray-900 font-medium"><%= @order.delivery_label %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-gray-900 text-lg mb-4">Status</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Payment</dt>
          <dd>
            <% if @order.paid? %>
              <span class="text-emerald-600 font-medium">Paid</span>
            <% else %>
              <span class="text-amber-600 font-medium">Unpaid</span>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Order</dt>
          <dd class="text-gray-700"><%= @order.status.humanize %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Reference</dt>
          <dd class="text-gray-700 font-mono text-xs"><%= @order.reference %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Date</dt>
          <dd class="text-gray-700"><%= @order.created_at.strftime("%d %b %Y %H:%M") %></dd>
        </div>
      </dl>

      <% if @order.paid? && @order.status != "collected" %>
        <div class="mt-4">
          <a href="<%= @order.whatsapp_url %>" target="_blank" rel="noopener" class="block text-center bg-emerald-600 hover:bg-emerald-700 text-white font-medium py-2.5 px-4 rounded-xl text-sm transition-colors">
            WhatsApp Customer
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>
