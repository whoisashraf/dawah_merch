<div class="mb-8">
  <span class="sticker-badge sticker-badge-yellow mb-2">SYSTEM CONFIG</span>
  <h1 class="font-display font-black text-3xl md:text-5xl mt-2 text-black">Settings</h1>
  <p class="text-xs font-bold text-gray-500 mt-1">Manage global system invite links and configs.</p>
</div>

<%= form_with url: admin_settings_path, method: :patch, class: "space-y-6 max-w-xl" do |f| %>
  <div class="neo-card bg-white p-6 space-y-4">
    <div>
      <h2 class="font-display font-black text-lg text-black mb-1">WhatsApp Group Link</h2>
      <p class="text-xs font-semibold text-gray-500 mb-4">Students will be invited to join this group after successful pre-order payment.</p>
      
      <%= f.label :whatsapp_group_link, "Group Invite URL", class: "block text-xs font-black uppercase tracking-wider mb-2 text-gray-700" %>
      <%= f.url_field :whatsapp_group_link, value: @whatsapp_link, placeholder: "https://chat.whatsapp.com/...",
        class: "neo-input text-sm" %>
    </div>
  </div>

  <div>
    <%= f.submit "Save Settings", class: "neo-btn-black cursor-pointer" %>
  </div>
<% end %>
