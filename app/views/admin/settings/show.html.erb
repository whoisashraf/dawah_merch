<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Settings</h1>
  <p class="text-gray-500 text-sm mt-1">Manage site configuration</p>
</div>

<%= form_with url: admin_settings_path, method: :patch, class: "space-y-6 max-w-xl" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
    <div>
      <h2 class="font-bold text-gray-900 text-lg mb-1">WhatsApp Group Link</h2>
      <p class="text-gray-500 text-sm mb-4">Students will be invited to join this group after successful payment.</p>
      <%= f.label :whatsapp_group_link, "Group Invite URL", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.url_field :whatsapp_group_link, value: @whatsapp_link, placeholder: "https://chat.whatsapp.com/...",
        class: "w-full rounded-xl border-gray-400 bg-white px-4 py-2.5 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 shadow-sm" %>
    </div>
  </div>

  <div>
    <%= f.submit "Save Settings", class: "bg-gray-900 hover:bg-gray-800 text-white font-medium py-2.5 px-6 rounded-xl transition-colors cursor-pointer" %>
  </div>
<% end %>
