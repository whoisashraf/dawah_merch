<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
    <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Total Revenue</p>
    <p class="text-3xl font-bold text-emerald-600 mt-1.5">₦<%= number_with_delimiter(@total_revenue / 100) %></p>
    <p class="text-gray-400 text-xs mt-1">From <%= @paid_orders %> paid <%= "order".pluralize(@paid_orders) %></p>
  </div>

  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
    <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Products</p>
    <p class="text-3xl font-bold text-gray-900 mt-1.5"><%= @products_count %></p>
    <p class="text-gray-400 text-xs mt-1">Active products in store</p>
  </div>

  <a href="<%= admin_orders_path(pending_proofread: "1") %>" class="block bg-white rounded-xl p-6 border border-gray-200 hover:border-amber-300 hover:shadow-md transition-all shadow-sm">
    <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Proofread</p>
    <p class="text-3xl font-bold <%= @pending_proofread > 0 ? 'text-amber-500' : 'text-gray-900' %> mt-1.5"><%= @pending_proofread %></p>
    <p class="text-gray-400 text-xs mt-1">Custom names awaiting review</p>
  </a>

  <a href="<%= admin_pickup_path %>" class="block bg-white rounded-xl p-6 border border-gray-200 hover:border-emerald-300 hover:shadow-md transition-all shadow-sm">
    <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Ready for Pickup</p>
    <p class="text-3xl font-bold <%= @uncollected > 0 ? 'text-emerald-600' : 'text-gray-900' %> mt-1.5"><%= @uncollected %></p>
    <p class="text-gray-400 text-xs mt-1">Orders waiting to be collected</p>
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
    <h2 class="font-bold text-gray-900">Recent Paid Orders</h2>
    <%= link_to "View all →", admin_orders_path, class: "text-sm text-emerald-600 hover:text-emerald-700 font-medium" %>
  </div>
  <% if @recent_orders.any? %>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left py-3 px-4 text-gray-500 font-semibold">Reference</th>
          <th class="text-left py-3 px-4 text-gray-500 font-semibold">Customer</th>
          <th class="text-left py-3 px-4 text-gray-500 font-semibold">Items</th>
          <th class="text-right py-3 px-4 text-gray-500 font-semibold">Amount</th>
          <th class="text-right py-3 px-4 text-gray-500 font-semibold">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @recent_orders.each do |order| %>
          <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= admin_order_path(order) %>'">
            <td class="py-3 px-4 font-mono text-xs text-emerald-600 font-medium"><%= order.reference %></td>
            <td class="py-3 px-4 text-gray-900 font-medium"><%= order.student_name %></td>
            <td class="py-3 px-4 text-gray-500"><%= order.order_items.sum(:quantity) %></td>
            <td class="py-3 px-4 text-right text-gray-900 font-medium"><%= naira(order.total_amount) %></td>
            <td class="py-3 px-4 text-right text-gray-400 text-xs"><%= order.created_at.strftime("%d %b, %I:%M %p") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="py-12 text-center text-gray-400 text-sm">No paid orders yet</div>
  <% end %>
</div>
