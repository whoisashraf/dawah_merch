<div class="mb-8">
  <span class="sticker-badge sticker-badge-yellow mb-2">MANAGEMENT PORTAL</span>
  <h1 class="font-display font-black text-3xl md:text-5xl mt-2 text-black">Dashboard ✦</h1>
  <p class="text-sm font-semibold text-gray-500 mt-1">Real-time Dawah Week merchandise pre-order statistics.</p>
</div>

<!-- Metrics Bento Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 mb-12">
  <!-- Total Revenue -->
  <div class="neo-card p-6 bg-white flex flex-col justify-between">
    <div>
      <span class="text-[10px] font-black uppercase tracking-widest text-gray-500">Total Revenue</span>
      <p class="text-3xl font-black text-accent-3 mt-2">₦<%= number_with_delimiter(@total_revenue / 100) %></p>
    </div>
    <p class="text-xs font-bold text-gray-400 mt-4">From <%= @paid_orders %> paid <%= "order".pluralize(@paid_orders) %></p>
  </div>

  <!-- Products -->
  <div class="neo-card p-6 bg-white flex flex-col justify-between">
    <div>
      <span class="text-[10px] font-black uppercase tracking-widest text-gray-500">Products</span>
      <p class="text-3xl font-black text-black mt-2"><%= @products_count %></p>
    </div>
    <p class="text-xs font-bold text-gray-400 mt-4">Active drops in shop</p>
  </div>

  <!-- Pending Proofread -->
  <a href="<%= admin_orders_path(pending_proofread: "1") %>" class="neo-card-yellow p-6 flex flex-col justify-between hover:translate-y-0.5 hover:shadow-none transition-all block">
    <div>
      <div class="flex justify-between items-start">
        <span class="text-[10px] font-black uppercase tracking-widest text-black">Awaiting Review</span>
        <% if @pending_proofread > 0 %>
          <span class="w-2.5 h-2.5 rounded-full bg-accent-2 animate-ping"></span>
        <% end %>
      </div>
      <p class="text-3xl font-black text-black mt-2"><%= @pending_proofread %></p>
    </div>
    <p class="text-xs font-black uppercase tracking-wider text-black mt-4 flex items-center gap-1">
      Proofread Names <%= "✦" if @pending_proofread > 0 %>
    </p>
  </a>

  <!-- Ready for Pickup -->
  <a href="<%= admin_pickup_path %>" class="neo-card p-6 bg-accent-1 text-black border-3 border-black flex flex-col justify-between hover:translate-y-0.5 hover:shadow-none transition-all block shadow-[6px_6px_0px_0px_#000000]">
    <div>
      <span class="text-[10px] font-black uppercase tracking-widest text-black">Ready for Pickup</span>
      <p class="text-3xl font-black text-black mt-2"><%= @uncollected %></p>
    </div>
    <p class="text-xs font-black uppercase tracking-wider text-black mt-4">Orders to Collect →</p>
  </a>
</div>

<!-- Recent Orders Table -->
<div class="neo-card bg-white overflow-hidden">
  <div class="px-6 py-5 border-b-3 border-black flex items-center justify-between bg-primary-bg/20">
    <h2 class="font-display font-black text-xl text-black">Recent Paid Orders ✦</h2>
    <div class="flex gap-2">
      <%= link_to "+ Offline Order", new_admin_order_path, class: "neo-btn-yellow py-1.5 px-4 text-xs font-black text-black border-2 border-black rounded-pill bg-accent-1" %>
      <%= link_to "View All", admin_orders_path, class: "neo-btn-black py-1.5 px-4 text-xs" %>
    </div>
  </div>
  
  <% if @recent_orders.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse text-left">
        <thead class="bg-white border-b-3 border-black font-black uppercase tracking-wider text-xs">
          <tr>
            <th class="py-3.5 px-6 border-r-2 border-black/10">Reference</th>
            <th class="py-3.5 px-6 border-r-2 border-black/10">Customer</th>
            <th class="py-3.5 px-6 border-r-2 border-black/10 text-center">Items</th>
            <th class="py-3.5 px-6 border-r-2 border-black/10 text-right">Amount</th>
            <th class="py-3.5 px-6 text-right">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y-2 divide-black/10 font-medium">
          <% @recent_orders.each do |order| %>
            <tr class="hover:bg-primary-bg/10 cursor-pointer transition-colors" onclick="window.location='<%= admin_order_path(order) %>'">
              <td class="py-3.5 px-6 font-mono text-xs text-accent-3 font-bold border-r-2 border-black/10"><%= order.reference %></td>
              <td class="py-3.5 px-6 text-black font-bold border-r-2 border-black/10"><%= order.student_name %></td>
              <td class="py-3.5 px-6 text-center border-r-2 border-black/10 font-bold"><%= order.order_items.sum(:quantity) %></td>
              <td class="py-3.5 px-6 text-right text-black font-black border-r-2 border-black/10"><%= naira(order.total_amount) %></td>
              <td class="py-3.5 px-6 text-right text-gray-500 text-xs"><%= order.created_at.strftime("%d %b, %I:%M %p") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="py-16 text-center text-gray-500 font-bold">No paid orders recorded yet.</div>
  <% end %>
</div>
