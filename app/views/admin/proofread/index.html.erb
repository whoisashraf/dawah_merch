<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Proofread Custom Names</h1>
  <p class="text-gray-500 text-sm mt-1">Review and approve custom names before production</p>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Order</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Student</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Product</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Size</th>
        <th class="text-left py-3 px-4 text-gray-600 font-semibold">Custom Name</th>
        <th class="text-right py-3 px-4 text-gray-600 font-semibold">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @order_items.each do |item| %>
        <tr class="hover:bg-gray-50">
          <td class="py-3 px-4 font-mono text-xs text-gray-700"><%= item.order.reference %></td>
          <td class="py-3 px-4 text-gray-900 font-medium"><%= item.order.student_name %></td>
          <td class="py-3 px-4 text-gray-600"><%= item.product.name %></td>
          <td class="py-3 px-4 text-gray-500"><%= item.size || "—" %></td>
          <td class="py-3 px-4">
            <span class="text-gray-900 font-medium">"<%= item.custom_name %>"</span>
          </td>
          <td class="py-3 px-4 text-right">
            <div class="flex justify-end gap-2">
              <%= button_to "Approve", approve_admin_proofread_path(item), method: :patch, class: "bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-medium py-1.5 px-3 rounded-lg transition-colors" %>
              <%= button_to "Reject", reject_admin_proofread_path(item), method: :patch, class: "bg-red-500 hover:bg-red-600 text-white text-xs font-medium py-1.5 px-3 rounded-lg transition-colors" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @order_items.empty? %>
        <tr>
          <td colspan="6" class="py-12 text-center text-gray-400">No pending proofread requests</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
