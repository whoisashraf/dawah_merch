<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
  <div>
    <span class="sticker-badge sticker-badge-yellow mb-2">CATALOG MANAGER</span>
    <h1 class="font-display font-black text-3xl md:text-5xl mt-2 text-black">Products ✦</h1>
    <p class="text-xs font-bold text-gray-500 mt-1">Manage drop status, options, custom name charges and image sets.</p>
  </div>
  <%= link_to "New Product ✦", new_admin_product_path, class: "neo-btn-black text-xs py-2 px-5" %>
</div>

<!-- Products Table Card -->
<div class="neo-card bg-white overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm border-collapse text-left">
      <thead class="bg-white border-b-3 border-black font-black uppercase tracking-wider text-xs">
        <tr>
          <th class="py-4 px-6 border-r-2 border-black/10">Image</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Name</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Slug</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-right">Base Price</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Option Types</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Custom Name</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Active</th>
          <th class="py-4 px-6"></th>
        </tr>
      </thead>
      <tbody class="divide-y-2 divide-black/10 font-semibold">
        <% @products.each do |product| %>
          <tr class="hover:bg-primary-bg/10 transition-colors">
            <td class="py-3 px-6 border-r-2 border-black/10">
              <% if product.images.attached? && product.images.any? %>
                <div class="relative w-12 h-12 overflow-hidden border-2 border-black rounded-lg bg-primary-bg flex items-center justify-center">
                  <%= image_tag product.images.first, class: "w-full h-full object-cover" %>
                </div>
              <% else %>
                <div class="w-12 h-12 border-2 border-black rounded-lg bg-primary-bg flex items-center justify-center text-2xl">
                  <%= product_icon(product) %>
                </div>
              <% end %>
            </td>
            <td class="py-3 px-6 text-black font-black text-base border-r-2 border-black/10"><%= product.name %></td>
            <td class="py-3 px-6 text-gray-500 font-mono text-xs border-r-2 border-black/10"><%= product.slug %></td>
            <td class="py-3 px-6 text-right text-black font-black text-base border-r-2 border-black/10"><%= naira(product.base_price) %></td>
            <td class="py-3 px-6 text-center text-xs border-r-2 border-black/10">
              <%= product.has_options? ? product.options.map { |o| o["name"] }.join(", ") : "—" %>
            </td>
            <td class="py-3 px-6 text-center border-r-2 border-black/10">
              <% if product.has_custom_name? %>
                <span class="border-2 border-black bg-accent-1 text-black text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]">Enabled</span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="py-3 px-6 text-center border-r-2 border-black/10">
              <% if product.active? %>
                <span class="border-2 border-black bg-accent-3 text-white text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]">Yes</span>
              <% else %>
                <span class="border-2 border-black bg-accent-2 text-white text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]">No</span>
              <% end %>
            </td>
            <td class="py-3 px-6 text-right">
              <%= link_to "Edit ✦", edit_admin_product_path(product), class: "text-accent-3 hover:text-black font-bold transition-colors" %>
            </td>
          </tr>
        <% end %>
        <% if @products.empty? %>
          <tr>
            <td colspan="8" class="py-16 text-center text-gray-500 font-bold">
              No products drop created yet. <%= link_to "Add one now →", new_admin_product_path, class: "text-accent-3 underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
