<div class="max-w-2xl mb-12">
  <div class="mb-6">
    <%= link_to admin_products_path, class: "inline-flex items-center gap-2 text-xs font-black uppercase tracking-wider text-gray-500 hover:text-black" do %>
      <span>←</span> Back to Products
    <% end %>
  </div>

  <h1 class="font-display font-black text-3xl md:text-4xl text-black mb-8">New Product</h1>

  <%= form_with model: @product, url: admin_products_path, class: "space-y-6" do |f| %>
    <div class="neo-card bg-white p-6 space-y-6">
      <div>
        <%= f.label :name, "Product Name", class: "block text-xs font-black uppercase tracking-wider mb-2 text-gray-700" %>
        <%= f.text_field :name, required: true, placeholder: "e.g. Dawah Week Hoodie",
          class: "neo-input text-sm" %>
      </div>

      <div>
        <%= f.label :base_price, "Base Price (₦)", class: "block text-xs font-black uppercase tracking-wider mb-2 text-gray-700" %>
        <%= f.number_field :base_price, required: true, min: 1, placeholder: "e.g. 6000",
          class: "neo-input text-sm" %>
        <p class="text-[10px] text-gray-500 font-bold mt-1.5 uppercase tracking-wider">Price in Naira. Enter the final catalog price.</p>
      </div>

      <!-- Options Builder -->
      <div class="border-t-2 border-black/10 pt-4">
        <span class="block text-xs font-black uppercase tracking-wider text-black mb-2">Options (e.g. Size, Color)</span>
        <p class="text-xs text-gray-500 mb-4 font-semibold">Define custom selector options. Separate values by commas.</p>
        <div id="option-rows" class="space-y-3">
          <% (@product.options || []).each_with_index do |option, i| %>
            <div class="option-row flex gap-2 items-center">
              <input type="text" name="product[options_config][<%= i %>][name]" value="<%= option['name'] %>"
                placeholder="e.g. Size"
                class="flex-1 neo-input text-sm py-2 px-3">
              <input type="text" name="product[options_config][<%= i %>][values]" value="<%= option['values'].join(', ') %>"
                placeholder="e.g. XXL, XL, L"
                class="flex-[2] neo-input text-sm py-2 px-3">
              <button type="button" onclick="this.closest('.option-row').remove()"
                class="w-10 h-10 shrink-0 rounded-lg border-2 border-black flex items-center justify-center font-bold text-lg text-accent-2 bg-white hover:bg-accent-2 hover:text-white transition-colors cursor-pointer">×</button>
            </div>
          <% end %>
        </div>
        <button type="button" id="add-option" onclick="addOptionRow()"
          class="mt-3 text-xs font-black uppercase tracking-wider text-accent-3 hover:underline flex items-center gap-1">
          + Add Option Row
        </button>
      </div>

      <div class="pt-4 border-t-2 border-black/10 flex flex-wrap gap-6">
        <label class="flex items-center gap-2.5 p-3 rounded-lg border-2 border-black hover:border-black/70 cursor-pointer transition-colors inline-flex bg-primary-bg/10 font-bold text-xs uppercase tracking-wider text-black select-none">
          <%= f.check_box :has_custom_name, class: "rounded border-black text-black focus:ring-black h-4 w-4" %>
          <span>Enable Custom Name Print</span>
        </label>
        
        <label class="flex items-center gap-2.5 p-3 rounded-lg border-2 border-black hover:border-black/70 cursor-pointer transition-colors inline-flex bg-primary-bg/10 font-bold text-xs uppercase tracking-wider text-black select-none">
          <%= f.check_box :active, checked: true, class: "rounded border-black text-black focus:ring-black h-4 w-4" %>
          <span>Active (Visible on Storefront)</span>
        </label>
      </div>

      <div>
        <%= f.label :custom_name_fee, "Custom Name Fee (₦)", class: "block text-xs font-black uppercase tracking-wider mb-2 text-gray-700" %>
        <%= f.number_field :custom_name_fee, min: 0, placeholder: "e.g. 1000",
          class: "neo-input text-sm" %>
        <p class="text-[10px] text-gray-500 font-bold mt-1.5 uppercase tracking-wider">Extra fee added when customer enters custom name print.</p>
      </div>

      <div class="pt-4 border-t-2 border-black/10">
        <%= f.label :images, "Upload Images (Supports Multiple Variants)", class: "block text-xs font-black uppercase tracking-wider mb-2 text-gray-700" %>
        <%= f.file_field :images, accept: "image/*", multiple: true,
          class: "w-full rounded-xl border-2 border-black bg-white px-4 py-3 text-gray-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-2 file:border-black file:text-xs file:font-black file:uppercase file:bg-accent-1 file:text-black hover:file:bg-black hover:file:text-white cursor-pointer shadow-[2px_2px_0px_0px_#000000]" %>
      </div>
    </div>

    <div class="flex gap-4">
      <%= f.submit "Create Product", class: "neo-btn-black py-3 px-8 cursor-pointer" %>
      <%= link_to "Cancel", admin_products_path, class: "neo-btn-outline py-3 px-8 text-center" %>
    </div>
  <% end %>
</div>

<script>
function addOptionRow() {
  const container = document.getElementById('option-rows');
  const idx = container.children.length;
  const div = document.createElement('div');
  div.className = 'option-row flex gap-2 items-center';
  div.innerHTML = `
    <input type="text" name="product[options_config][${idx}][name]"
      placeholder="e.g. Size"
      class="flex-1 neo-input text-sm py-2 px-3">
    <input type="text" name="product[options_config][${idx}][values]"
      placeholder="e.g. XXL, XL, L"
      class="flex-[2] neo-input text-sm py-2 px-3">
    <button type="button" onclick="this.closest('.option-row').remove()"
      class="w-10 h-10 shrink-0 rounded-lg border-2 border-black flex items-center justify-center font-bold text-lg text-accent-2 bg-white hover:bg-accent-2 hover:text-white transition-colors cursor-pointer">×</button>
  `;
  container.appendChild(div);
}
</script>
