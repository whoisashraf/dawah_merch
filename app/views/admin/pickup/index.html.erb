<div class="mb-8">
  <span class="sticker-badge sticker-badge-yellow mb-2">PICKUP LOGISTICS</span>
  <h1 class="font-display font-black text-3xl md:text-5xl mt-2 text-black">Pickup Tracker ✦</h1>
  <p class="text-xs font-bold text-gray-500 mt-1">Search student name or reference to verify payment and mark as collected.</p>
</div>

<!-- Search Form -->
<div class="neo-card bg-white p-6 mb-8">
  <%= form_with url: admin_pickup_path, method: :get, class: "flex flex-col sm:flex-row gap-3" do |f| %>
    <%= text_field_tag :q, params[:q], placeholder: "Search by reference, student name, or phone...",
      class: "flex-1 neo-input text-sm" %>
    <%= submit_tag "Search ✦", class: "neo-btn-black py-2.5 px-6 text-xs cursor-pointer" %>
  <% end %>
</div>

<!-- Pickup Table -->
<div class="neo-card bg-white overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm border-collapse text-left">
      <thead class="bg-white border-b-3 border-black font-black uppercase tracking-wider text-xs">
        <tr>
          <th class="py-4 px-6 border-r-2 border-black/10">Reference</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Student</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Phone</th>
          <th class="py-4 px-6 border-r-2 border-black/10">Delivery</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Items</th>
          <th class="py-4 px-6 border-r-2 border-black/10 text-center">Status</th>
          <th class="py-4 px-6"></th>
        </tr>
      </thead>
      <tbody class="divide-y-2 divide-black/10 font-semibold">
        <% @orders.each do |order| %>
          <tr class="hover:bg-primary-bg/10 transition-colors">
            <td class="py-3.5 px-6 font-mono text-xs text-accent-3 font-bold border-r-2 border-black/10"><%= order.reference %></td>
            <td class="py-3.5 px-6 text-black font-bold border-r-2 border-black/10"><%= order.student_name %></td>
            <td class="py-3.5 px-6 text-gray-600 border-r-2 border-black/10"><%= order.phone %></td>
            <td class="py-3.5 px-6 text-gray-500 text-xs border-r-2 border-black/10"><%= order.delivery_label %></td>
            <td class="py-3.5 px-6 text-center border-r-2 border-black/10 font-bold"><%= order.order_items.sum(:quantity) %></td>
            <td class="py-3.5 px-6 text-center border-r-2 border-black/10">
              <% if order.status == 'collected' %>
                <span class="border-2 border-black bg-accent-3 text-white text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]">Collected</span>
              <% else %>
                <span class="border-2 border-black bg-accent-1 text-black text-[10px] font-black uppercase px-2 py-0.5 rounded shadow-[1px_1px_0px_0px_#000000]"><%= order.status.humanize %></span>
              <% end %>
            </td>
            <td class="py-3.5 px-6 text-right">
              <div class="flex justify-end gap-2">
                <% if order.status != "collected" %>
                  <%= button_to "Mark Collected ✦", admin_pickup_collect_path(order), method: :patch,
                    class: "border-2 border-black bg-white text-black hover:bg-black hover:text-white px-3.5 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-all cursor-pointer shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5" %>
                <% end %>
                <a href="<%= order.whatsapp_url %>" target="_blank" rel="noopener"
                  class="border-2 border-black bg-accent-1 text-black hover:bg-black hover:text-white px-3.5 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-all cursor-pointer shadow-[2px_2px_0px_0px_#000000] hover:shadow-none hover:translate-y-0.5">
                  WhatsApp
                </a>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @orders.empty? %>
          <tr>
            <td colspan="7" class="py-16 text-center text-gray-500 font-bold">
              <%= params[:q].present? ? "No orders matched your search query." : "No pending collections right now." %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
