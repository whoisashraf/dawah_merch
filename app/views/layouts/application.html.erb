<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Doxaclasm Warfare | FUTMINNA MSSN Dawah Week" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-900">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <%= link_to new_order_path, class: "flex items-center gap-3 hover:opacity-80 transition-opacity" do %>
            <span class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-700 to-emerald-600 flex items-center justify-center text-white text-xs font-black tracking-wider">DW</span>
            <div>
              <span class="font-bold text-gray-900 block leading-tight text-sm">DOXACLASM WARFARE</span>
              <span class="text-[11px] text-gray-400 block leading-tight tracking-wide">FUTMINNA MSSN · Dawah Week</span>
            </div>
          <% end %>

          <div class="flex items-center gap-5">
            <% if authenticated? %>
              <%= link_to "Admin", admin_path, class: "text-sm text-gray-500 hover:text-gray-800 font-medium transition-colors" %>
              <%= button_to "Log out", session_path, method: :delete, class: "text-sm text-gray-400 hover:text-red-500 font-medium transition-colors bg-transparent border-none cursor-pointer" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="max-w-7xl mx-auto mt-4 px-4 sm:px-6 lg:px-8 flash-notice">
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-7xl mx-auto mt-4 px-4 sm:px-6 lg:px-8 flash-alert">
        <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <script>
      setTimeout(() => {
        document.querySelectorAll('.flash-notice, .flash-alert').forEach(el => {
          el.style.transition = 'opacity 0.5s';
          el.style.opacity = '0';
          setTimeout(() => el.remove(), 500);
        });
      }, 3000);
    </script>

    <footer class="border-t border-gray-100 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center">
        <p class="text-xs text-gray-400">FUTMINNA Muslim Students' Society — Doxaclasm Warfare · Dawah Week 2026</p>
      </div>
    </footer>
  </body>
</html>
