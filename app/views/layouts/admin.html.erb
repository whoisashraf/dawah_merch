<!DOCTYPE html>
<html>
  <head>
    <title>Admin | Doxaclasm Warfare</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-900">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-14 items-center">
          <div class="flex items-center gap-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-700 to-emerald-600 flex items-center justify-center text-white text-xs font-black">DW</span>
            <span class="text-gray-300 text-sm">|</span>
            <div class="flex items-center gap-1">
              <%= link_to "Dashboard", admin_dashboard_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'dashboard' ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-800 hover:bg-gray-100'}" %>
              <%= link_to "Orders", admin_orders_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{%w[orders proofread production pickup].include?(controller_name) ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-800 hover:bg-gray-100'}" %>
              <%= link_to "Products", admin_products_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'products' ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-800 hover:bg-gray-100'}" %>
              <%= link_to "Settings", admin_settings_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'settings' ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-800 hover:bg-gray-100'}" %>
            </div>
          </div>
          <div class="flex items-center">
            <%= button_to "Logout", session_path, method: :delete, class: "text-xs text-gray-400 hover:text-red-500 font-medium transition-colors bg-transparent border-none cursor-pointer" %>
          </div>
        </div>
      </div>
    </nav>

    <% if %w[orders proofread production pickup].include?(controller_name) %>
      <div class="border-b border-gray-200 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex gap-4 -mb-px">
            <%= link_to "All Orders", admin_orders_path, class: "py-3 px-1 text-sm font-medium border-b-2 transition-colors #{controller_name == 'orders' && action_name != 'show' ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300'}" %>
            <%= link_to "Proofread", admin_proofread_index_path, class: "py-3 px-1 text-sm font-medium border-b-2 transition-colors #{controller_name == 'proofread' ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300'}" %>
            <%= link_to "Production", admin_production_path, class: "py-3 px-1 text-sm font-medium border-b-2 transition-colors #{controller_name == 'production' ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300'}" %>
            <%= link_to "Pickup", admin_pickup_path, class: "py-3 px-1 text-sm font-medium border-b-2 transition-colors #{controller_name == 'pickup' ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300'}" %>
          </div>
        </div>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="max-w-7xl mx-auto mt-4 px-4 sm:px-6 lg:px-8 flash-notice">
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-7xl mx-auto mt-4 px-4 sm:px-6 lg:px-8 flash-alert">
        <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <script>
      setTimeout(() => {
        document.querySelectorAll('.flash-notice, .flash-alert').forEach(el => {
          el.style.transition = 'opacity 0.5s';
          el.style.opacity = '0';
          setTimeout(() => el.remove(), 500);
        });
      }, 3000);
    </script>
  </body>
</html>
