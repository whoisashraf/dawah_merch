<!DOCTYPE html>
<html>
  <head>
    <title>Admin | Doxaclasm Warfare</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#FCFAF2] min-h-screen text-black antialiased selection:bg-accent-1 selection:text-black">
    <!-- Admin Navigation -->
    <nav class="bg-white border-b-3 border-black sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center gap-6">
            <%= link_to admin_dashboard_path, class: "flex items-center gap-3 hover:opacity-90 transition-opacity" do %>
              <div class="relative w-8 h-8 shrink-0">
                <div class="absolute inset-0 bg-black rounded-lg border-2 border-black rotate-6"></div>
                <div class="absolute -inset-0.5 bg-accent-1 rounded-full border-2 border-black -translate-x-1 translate-y-0.5 rotate-12 flex items-center justify-center text-[10px] font-black text-black">DW</div>
              </div>
              <span class="font-display font-black text-black text-sm tracking-tight">DW ADMIN</span>
            <% end %>
            <span class="text-gray-300">|</span>
            <div class="flex items-center gap-1">
              <%= link_to "Dashboard", admin_dashboard_path, class: "px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-colors #{controller_name == 'dashboard' ? 'bg-black text-white' : 'text-gray-600 hover:text-black hover:bg-gray-100'}" %>
              <%= link_to "Orders", admin_orders_path, class: "px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-colors #{%w[orders proofread production pickup].include?(controller_name) ? 'bg-black text-white' : 'text-gray-600 hover:text-black hover:bg-gray-100'}" %>
              <%= link_to "Products", admin_products_path, class: "px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-colors #{controller_name == 'products' ? 'bg-black text-white' : 'text-gray-600 hover:text-black hover:bg-gray-100'}" %>
              <%= link_to "Settings", admin_settings_path, class: "px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition-colors #{controller_name == 'settings' ? 'bg-black text-white' : 'text-gray-600 hover:text-black hover:bg-gray-100'}" %>
            </div>
          </div>
          <div class="flex items-center">
            <%= button_to "LOGOUT", session_path, method: :delete, class: "text-xs font-black text-accent-2 tracking-wider bg-transparent border-none cursor-pointer hover:underline" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Subnav for Order related actions -->
    <% if %w[orders proofread production pickup].include?(controller_name) %>
      <div class="border-b-3 border-black bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex gap-6 -mb-px">
            <%= link_to "All Orders", admin_orders_path, class: "py-3 text-xs font-black uppercase tracking-wider border-b-4 transition-all #{controller_name == 'orders' && action_name != 'show' ? 'border-black text-black' : 'border-transparent text-gray-400 hover:text-black'}" %>
            <%= link_to "Proofread", admin_proofread_index_path, class: "py-3 text-xs font-black uppercase tracking-wider border-b-4 transition-all #{controller_name == 'proofread' ? 'border-black text-black' : 'border-transparent text-gray-400 hover:text-black'}" %>
            <%= link_to "Production", admin_production_path, class: "py-3 text-xs font-black uppercase tracking-wider border-b-4 transition-all #{controller_name == 'production' ? 'border-black text-black' : 'border-transparent text-gray-400 hover:text-black'}" %>
            <%= link_to "Pickup", admin_pickup_path, class: "py-3 text-xs font-black uppercase tracking-wider border-b-4 transition-all #{controller_name == 'pickup' ? 'border-black text-black' : 'border-transparent text-gray-400 hover:text-black'}" %>
          </div>
        </div>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="max-w-7xl mx-auto mt-6 px-4 sm:px-6 lg:px-8 flash-notice">
        <div class="bg-accent-1 border-3 border-black text-black font-extrabold text-sm rounded-card px-5 py-4 flex items-center gap-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <svg class="w-5 h-5 shrink-0 stroke-current fill-none stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-7xl mx-auto mt-6 px-4 sm:px-6 lg:px-8 flash-alert">
        <div class="bg-accent-2 border-3 border-black text-white font-extrabold text-sm rounded-card px-5 py-4 flex items-center gap-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <svg class="w-5 h-5 shrink-0 stroke-current fill-none stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <script>
      setTimeout(() => {
        document.querySelectorAll('.flash-notice, .flash-alert').forEach(el => {
          el.style.transition = 'all 0.5s ease-in-out';
          el.style.opacity = '0';
          el.style.transform = 'translateY(-10px)';
          setTimeout(() => el.remove(), 500);
        });
      }, 3000);
    </script>
  </body>
</html>
