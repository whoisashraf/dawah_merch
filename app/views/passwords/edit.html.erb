<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="neo-card bg-white overflow-hidden shadow-[8px_8px_0px_0px_#000000]">
      <div class="px-8 pt-8 pb-6 text-center border-b-3 border-black bg-primary-bg/10 relative grain-bg">
        <div class="absolute top-3 right-3 text-xl font-black sparkle-icon animate-float">✦</div>
        <h1 class="font-display font-black text-2xl text-black">UPDATE PASSWORD</h1>
        <p class="text-xs font-bold text-gray-500 mt-1 uppercase tracking-wider">Set a secure new password</p>
      </div>

      <%= form_with url: password_path(params[:token]), method: :put, class: "px-8 py-8 space-y-6" do |form| %>
        <% if alert = flash[:alert] %>
          <div class="bg-accent-2 border-3 border-black text-white font-extrabold text-sm rounded-card px-5 py-4 flex items-center gap-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <svg class="w-5 h-5 shrink-0 stroke-current fill-none stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <%= alert %>
          </div>
        <% end %>

        <div>
          <%= form.label :password, "New Password", class: "block text-xs font-black uppercase tracking-wider mb-2 text-black" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password",
            placeholder: "Enter new password",
            maxlength: 72,
            class: "neo-input text-sm placeholder:text-gray-400" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm Password", class: "block text-xs font-black uppercase tracking-wider mb-2 text-black" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
            placeholder: "Repeat new password",
            maxlength: 72,
            class: "neo-input text-sm placeholder:text-gray-400" %>
        </div>

        <div class="flex flex-col gap-4">
          <%= form.submit "SAVE PASSWORD ✦",
            class: "w-full neo-btn-black cursor-pointer" %>
          
          <%= link_to "← Back to Login", new_session_path, class: "text-center text-xs font-black uppercase tracking-wider text-accent-3 hover:underline py-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
