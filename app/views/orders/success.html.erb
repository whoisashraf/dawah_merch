<div class="max-w-2xl mx-auto my-12">
  <% if @verified %>
    <!-- Success Ticket -->
    <div class="bg-primary-bg rounded-card border-3 border-black shadow-[8px_8px_0px_0px_#000000] overflow-hidden grain-bg mb-8 relative">
      
      <!-- Ticket Header -->
      <div class="bg-black text-white px-6 py-6 border-b-3 border-black flex justify-between items-center relative">
        <div class="absolute -bottom-2.5 left-0 right-0 flex justify-around">
          <% 8.times do %>
            <div class="w-5 h-5 bg-primary-bg border-t-3 border-black rotate-45 transform"></div>
          <% end %>
        </div>
        <div>
          <span class="sticker-badge sticker-badge-yellow text-xs">ORDER CONFIRMED</span>
          <h1 class="font-display font-black text-2xl md:text-3xl text-white mt-2">Doxaclasm Receipt</h1>
        </div>
        <div class="text-6xl animate-float">🔥</div>
      </div>

      <!-- Ticket Body -->
      <div class="p-6 md:p-8 space-y-6">
        <div class="text-center py-4">
          <div class="w-16 h-16 rounded-full bg-accent-1 border-3 border-black flex items-center justify-center mx-auto mb-4 shadow-[3px_3px_0px_0px_#000000] rotate-12">
            <span class="text-black font-black text-2xl">✓</span>
          </div>
          <h2 class="font-display font-black text-xl text-black">Payment Verified!</h2>
          <p class="text-sm text-gray-700 mt-2 font-medium">Your pre-order has been secured. We'll reach out when your gear is ready for pickup.</p>
        </div>

        <!-- Join WhatsApp Group Button (Sticker style) -->
        <% if @whatsapp_group_link.present? %>
          <div class="bg-white border-3 border-black rounded-card p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] text-center relative overflow-hidden">
            <span class="text-2xl block mb-2">📢</span>
            <h3 class="font-display font-black text-lg text-black mb-1">Join the Dawah Week Community</h3>
            <p class="text-xs text-gray-600 mb-4 max-w-sm mx-auto font-medium">Get real-time updates on order collection dates, event schedules, and join the conversation.</p>
            <a href="<%= @whatsapp_group_link %>" target="_blank" rel="noopener" class="neo-btn-yellow w-full py-3">
              Join WhatsApp Group
            </a>
          </div>
        <% end %>

        <!-- Order Summary details -->
        <div class="bg-white rounded-card border-3 border-black p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <h3 class="font-display font-black text-lg text-black mb-4 border-b-2 border-black/10 pb-2">Ticket Summary</h3>
          <div class="grid grid-cols-2 gap-y-3 text-xs md:text-sm font-semibold">
            <span class="text-gray-500 uppercase tracking-wider">Reference</span>
            <span class="text-black font-mono text-right"><%= @order.reference %></span>

            <span class="text-gray-500 uppercase tracking-wider">Customer</span>
            <span class="text-black text-right"><%= @order.student_name %></span>

            <span class="text-gray-500 uppercase tracking-wider">Level</span>
            <span class="text-black text-right"><%= @order.level %></span>

            <span class="text-gray-500 uppercase tracking-wider">Department</span>
            <span class="text-black text-right"><%= @order.department %></span>

            <span class="text-gray-500 uppercase tracking-wider">Phone</span>
            <span class="text-black text-right"><%= @order.phone %></span>

            <span class="text-gray-500 uppercase tracking-wider">Delivery</span>
            <span class="text-black text-right"><%= @order.delivery_label %></span>

            <span class="text-gray-500 uppercase tracking-wider">Total Paid</span>
            <span class="text-accent-3 font-black text-right text-base"><%= naira(@order.total_amount) %></span>
          </div>

          <!-- Items list -->
          <div class="border-t-3 border-dashed border-black/20 pt-6 mt-6">
            <h4 class="font-display font-black text-base text-black mb-3">Items Ordered</h4>
            <div class="space-y-3">
              <% @order.order_items.each do |item| %>
                <div class="flex justify-between items-center text-xs md:text-sm bg-primary-bg border-2 border-black rounded-lg p-3 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                  <div>
                    <span class="font-black text-black block"><%= item.product.name %></span>
                    <% if item.selected_options.present? %>
                      <span class="text-[10px] text-gray-500 font-bold block mt-0.5">(<%= item.selected_options.values.join(", ") %>)</span>
                    <% end %>
                    <% if item.custom_name.present? %>
                      <span class="text-xs text-accent-3 font-extrabold block mt-0.5">Print Name: "<%= item.custom_name %>"</span>
                    <% end %>
                  </div>
                  <span class="text-black font-black bg-accent-1 border-2 border-black rounded-md px-2 py-0.5 text-xs">
                    ×<%= item.quantity %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Payment Pending -->
    <div class="bg-primary-bg rounded-card border-3 border-black shadow-[8px_8px_0px_0px_#000000] p-8 text-center grain-bg mb-8">
      <div class="w-16 h-16 rounded-full bg-accent-2 border-3 border-black flex items-center justify-center mx-auto mb-5 shadow-[3px_3px_0px_0px_#000000] rotate-12">
        <span class="text-white text-3xl font-black">!</span>
      </div>
      <h1 class="font-display font-black text-3xl text-black mb-2">Payment Pending</h1>
      <p class="text-gray-700 font-medium mb-6">Your transaction has not been confirmed yet. If you have completed the payment, please refresh this page.</p>
      
      <div class="bg-white border-2 border-black p-4 rounded-lg font-mono text-xs text-gray-500 inline-block">
        Reference: <strong class="text-black font-bold"><%= @order.reference %></strong>
      </div>
      <p class="text-xs text-gray-400 mt-6">If you continue to experience issues, please contact the MSSN team with your reference code.</p>
    </div>
  <% end %>

  <div class="text-center">
    <%= link_to new_order_path, class: "neo-btn-outline" do %>
      ← Place Another Order
    <% end %>
  </div>
</div>
