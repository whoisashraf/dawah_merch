<div class="max-w-2xl mx-auto">
  <% if @verified %>
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-10 text-center mb-6">
      <div class="w-16 h-16 rounded-2xl bg-emerald-100 flex items-center justify-center mx-auto mb-5">
        <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
      <p class="text-gray-500 mb-6">Your pre-order has been received. We'll reach out when it's ready for pickup.</p>

      <!-- Join WhatsApp Group -->
      <% if @whatsapp_group_link.present? %>
        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5 mb-6">
          <div class="text-3xl mb-2">📢</div>
          <h3 class="font-bold text-gray-900 mb-1">Join the Dawah Week Group</h3>
          <p class="text-sm text-gray-600 mb-4">Get updates on order collection, event schedules, and connect with the community.</p>
          <a href="<%= @whatsapp_group_link %>" target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-6 rounded-xl transition-all shadow-md hover:shadow-lg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Join WhatsApp Group
          </a>
        </div>
      <% end %>

      <!-- Order Summary -->
      <div class="bg-gray-50 rounded-xl p-6 text-left border border-gray-100">
        <h2 class="font-semibold text-gray-900 mb-4 text-left">Order Summary</h2>
        <div class="grid grid-cols-2 gap-y-2.5 text-sm">
          <span class="text-gray-500">Reference</span>
          <span class="text-gray-900 font-mono font-medium text-right"><%= @order.reference %></span>

          <span class="text-gray-500">Name</span>
          <span class="text-gray-900 font-medium text-right"><%= @order.student_name %></span>

          <span class="text-gray-500">Level</span>
          <span class="text-gray-900 text-right"><%= @order.level %></span>

          <span class="text-gray-500">Dept</span>
          <span class="text-gray-900 text-right"><%= @order.department %></span>

          <span class="text-gray-500">Phone</span>
          <span class="text-gray-900 text-right"><%= @order.phone %></span>

          <span class="text-gray-500">Delivery</span>
          <span class="text-gray-900 font-medium text-right"><%= @order.delivery_label %></span>

          <span class="text-gray-500">Total</span>
          <span class="text-emerald-700 font-bold text-right text-lg"><%= naira(@order.total_amount) %></span>
        </div>

        <div class="border-t border-gray-200 pt-4 mt-4">
          <h3 class="font-semibold text-gray-800 text-sm mb-3">Items</h3>
          <div class="space-y-2">
            <% @order.order_items.each do |item| %>
              <div class="flex justify-between items-center text-sm bg-white rounded-lg px-3 py-2 border border-gray-100">
                <span class="text-gray-700">
                  <%= item.product.name %>
                  <% if item.selected_options.present? %>
                    <span class="text-gray-400">(<%= item.selected_options.values.join(", ") %>)</span>
                  <% end %>
                  <% if item.custom_name.present? %>
                    <span class="text-emerald-600 font-medium">"<%= item.custom_name %>"</span>
                  <% end %>
                </span>
                <span class="text-gray-500 font-medium">×<%= item.quantity %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-10 text-center mb-6">
      <div class="w-16 h-16 rounded-2xl bg-amber-100 flex items-center justify-center mx-auto mb-5">
        <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Payment Pending</h1>
      <p class="text-gray-500 mb-4">Your payment hasn't been confirmed yet.</p>
      <p class="text-sm text-gray-400">Reference: <strong class="font-mono"><%= @order.reference %></strong></p>
      <p class="text-sm text-gray-400 mt-4">Refresh this page or contact the MSSN team if you've already paid.</p>
    </div>
  <% end %>

  <div class="text-center">
    <%= link_to "← Place Another Order", new_order_path, class: "text-gray-500 hover:text-gray-700 font-medium transition-colors" %>
  </div>
</div>
